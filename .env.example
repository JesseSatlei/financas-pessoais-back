PORT=3000
FRONTEND_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Opcional: quando definido, usa URL (ex: Neon) e ignora DB_HOST/DB_PORT/...
# Exemplo:
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=financas
DB_PASSWORD=financas
DB_DATABASE=financas
# Opcional: força SSL mesmo sem DATABASE_URL
DB_SSL=false
DB_SYNCHRONIZE=true

JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d
