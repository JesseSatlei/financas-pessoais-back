PORT=3000
FRONTEND_ORIGIN=http://localhost:8080,http://127.0.0.1:8080
# Se quiser liberar qualquer origem (não recomendado), use:
# FRONTEND_ORIGIN=*

# Opcional: quando definido, usa URL (ex: Neon) e ignora DB_HOST/DB_PORT/...
# Exemplo:
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=financas
DB_PASSWORD=financas
DB_DATABASE=financas
# Opcional: força SSL mesmo sem DATABASE_URL
DB_SSL=false
DB_SYNCHRONIZE=true

JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d

# Admin (criado/atualizado no startup)
# Use o mesmo login do /auth/signin (email/senha)
ADMIN_ENABLED=true
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@bolso.local
ADMIN_PASSWORD=change-me
# Se true, reseta a senha do admin a cada boot
ADMIN_ROTATE_PASSWORD=false
